# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/precision

# JWT Configuration
# ⚠️ OBLIGATORIO: Generar una key segura con: openssl rand -hex 32
# Nunca usar la misma key en diferentes ambientes (dev/prod)
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_32

# Sentinel-2 / Copernicus DataSpace Credentials
# Obtén tus credenciales en: https://dataspace.copernicus.eu/
SENTINEL_CLIENT_ID=your_client_id_here
SENTINEL_CLIENT_SECRET=your_client_secret_here

# Application Settings
DEBUG=True
